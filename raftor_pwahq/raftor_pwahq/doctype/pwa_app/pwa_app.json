{
  "doctype": "DocType",
  "name": "PWA App",
  "module": "Raftor Pwahq",
  "istable": 0,
  "issingle": 0,
  "autoname": "field:app_name",
  "title_field": "app_name",
  "fields": [
    {"fieldname":"enabled",        "fieldtype":"Check",      "label":"Enabled",         "default":"1", "bold":1, "in_list_view":1},
    {"fieldname":"app_name",       "fieldtype":"Data",       "label":"App Name",        "reqd":1, "bold":1, "description":"Full name shown in manifest and install prompt"},
    {"fieldname":"short_name",     "fieldtype":"Data",       "label":"Short Name",      "reqd":1, "description":"Max 12 chars — shown under homescreen icon"},
    {"fieldname":"col_break_1",    "fieldtype":"Column Break"},
    {"fieldname":"theme_color",    "fieldtype":"Color",      "label":"Theme Colour",    "default":"#1a1a2e", "description":"Browser chrome / status bar"},
    {"fieldname":"background_color","fieldtype":"Color",     "label":"Background Colour","default":"#ffffff","description":"Splash screen background"},
    {"fieldname":"identity_sec",   "fieldtype":"Section Break","label":"Identity"},
    {"fieldname":"start_url",      "fieldtype":"Data",       "label":"Start URL",       "reqd":1, "default":"/"},
    {"fieldname":"display_mode",   "fieldtype":"Select",     "label":"Display Mode",    "options":"standalone\nfullscreen\nminimal-ui\nbrowser","default":"standalone"},
    {"fieldname":"orientation",    "fieldtype":"Select",     "label":"Orientation",     "options":"portrait-primary\nportrait\nlandscape\nany","default":"portrait-primary"},
    {"fieldname":"col_break_2",    "fieldtype":"Column Break"},
    {"fieldname":"description",    "fieldtype":"Small Text", "label":"Description"},
    {"fieldname":"scope_mode",     "fieldtype":"Select",     "label":"Scope Mode",      "options":"sitewide\nscoped","default":"sitewide","description":"sitewide: inject shell on every page. scoped: inject only on start_url and nav item routes."},
    {"fieldname":"nav_sec",        "fieldtype":"Section Break","label":"Bottom Navigation","collapsible":1},
    {"fieldname":"nav_items",      "fieldtype":"Table",      "label":"Nav Items",       "options":"PWA Nav Item"},
    {"fieldname":"desk_sec",       "fieldtype":"Section Break","label":"Desk Navigation","collapsible":1,
     "description":"Wrap the Frappe Desk with the PWA shell when admins use it on mobile"},
    {"fieldname":"desk_enabled",   "fieldtype":"Check",      "label":"Enable Desk Shell"},
    {"fieldname":"desk_nav_items", "fieldtype":"Table",      "label":"Desk Nav Items",  "options":"PWA Desk Nav Item",
     "depends_on":"eval:doc.desk_enabled"},
    {"fieldname":"sw_sec",         "fieldtype":"Section Break","label":"Service Worker", "collapsible":1},
    {"fieldname":"cache_version",  "fieldtype":"Data",       "label":"Cache Version",   "default":"v1","description":"Bump to force all clients to re-fetch cached assets"},
    {"fieldname":"offline_url",    "fieldtype":"Data",       "label":"Offline Fallback URL","default":"/offline"},
    {"fieldname":"col_break_3",    "fieldtype":"Column Break"},
    {"fieldname":"push_enabled",      "fieldtype":"Check",  "label":"Enable Push Notifications"},
    {"fieldname":"vapid_public_key",  "fieldtype":"Data",   "label":"VAPID Public Key",  "read_only":1, "no_copy":1, "description":"Auto-generated when push is enabled. Used as applicationServerKey in the browser."},
    {"fieldname":"vapid_private_key", "fieldtype":"Password","label":"VAPID Private Key","read_only":1, "no_copy":1, "hidden":1},
    {"fieldname":"show_install_prompt","fieldtype":"Check",  "label":"Show Install Prompt","default":"1"},
    {"fieldname":"icons_sec",      "fieldtype":"Section Break","label":"Icons",          "collapsible":1},
    {"fieldname":"icons",          "fieldtype":"Table",      "label":"Icons",            "options":"PWA Icon"},
    {"fieldname":"screenshots_sec","fieldtype":"Section Break","label":"Screenshots",    "collapsible":1},
    {"fieldname":"screenshots",    "fieldtype":"Table",      "label":"Screenshots",      "options":"PWA Screenshot"}
  ],
  "permissions": [
    {"role":"System Manager","read":1,"write":1,"create":1,"delete":1}
  ]
}
